# ==========================================
# PUBLIC VARIABLES (Client-side access)
# ==========================================

# Supabase URL and Anon Key (Public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GetStream API Key (Public for chat/video)
NEXT_PUBLIC_STREAM_KEY=

# Paystack Public Key (For client-side checkout)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Push Notification VAPID Public Key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# App URLs (set to your Vercel URL or custom domain in production)
# In Vercel: https://your-project.vercel.app
# Custom domain: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# DATABASE (Prisma)
# ==========================================

# PostgreSQL connection strings
DATABASE_URL=
DIRECT_URL=

# ==========================================
# SECRET VARIABLES (Server-side ONLY — NEVER expose to browser)
# ==========================================

# Supabase Service Role Key (Admin rights)
SUPABASE_SERVICE_ROLE_KEY=

# Paystack Secret Key (For verifying transactions)
PAYSTACK_SECRET_KEY=

# GetStream Secret Key (For generating tokens)
STREAM_SECRET=

# OpenRouter API Key (For AI generation)
OPENROUTER_API_KEY=

# Google AI / Gemini
GOOGLE_AI_KEY=
PROJECT_NUMBER=

# Push Notification VAPID Private Key
VAPID_PRIVATE_KEY=

# Resend (Email service)
RESEND_API_KEY=

# M-Pesa Keys (For mobile payments)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=

# Admin configuration
ADMIN_EMAIL_1=
ADMIN_EMAIL_2=
ADMIN_SECRET_KEY=

# Cron job authentication
CRON_SECRET=
