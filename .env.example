# ==========================================
# PUBLIC VARIABLES (Client-side access)
# ==========================================

# Supabase URL and Anon Key (Public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GetStream API Key (Public for chat/video)
NEXT_PUBLIC_STREAM_API_KEY=

# Paystack Public Key (For client-side checkout)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ==========================================
# SECRET VARIABLES (Server-side ONLY)
# ==========================================

# Supabase Service Role Key (Admin rights, NEVER share)
SUPABASE_SERVICE_ROLE_KEY=

# Paystack Secret Key (For verifying transactions, NEVER share)
PAYSTACK_SECRET_KEY=

# GetStream Secret Key (For generating tokens, NEVER share)
STREAM_SECRET_KEY=

# OpenRouter API Key (For AI generation, NEVER share)
OPENROUTER_API_KEY=

# M-Pesa Keys (For mobile payments, NEVER share)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=

# Admin Emails (Mash only)
ADMIN_EMAIL_1=
ADMIN_EMAIL_2=
