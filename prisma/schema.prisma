generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  phone             String?                 @unique
  name              String
  avatar            String?
  role              Role                    @default(STUDENT)
  educationLevel    EduLevel?
  curriculum        String?                 @default("8-4-4")
  formYear          Int?
  county            String
  points            Int                     @default(0)
  tier              Tier                    @default(BRONZE)
  streakDays        Int                     @default(0)
  lastActiveAt      DateTime?
  isUnder18         Boolean                 @default(false)
  strikes           Int                     @default(0)
  createdAt         DateTime                @default(now())
  bio               String?
  settings          Json                    @default("{\"theme\": \"system\", \"fontSize\": \"medium\", \"accentColor\": \"#8b5cf6\"}")
  achievements      Achievement[]
  comments          Comment[]
  challenges        DailyChallengeAttempt[]
  feedPosts         FeedPost[]
  messages          Message[]
  notifications     Notification[]
  postLikes         PostLike[]
  reviewsRecv       Review[]                @relation("Reviewee")
  reviewsGiven      Review[]                @relation("Reviewer")
  sessionsAsTutor   Session[]               @relation("TutorSessions")
  sessionsAsStudent Session[]               @relation("StudentSessions")
  studentProfile    StudentProfile?
  tutorProfile      TutorProfile?
  tutorApplication  TutorApplication?
}

model StudentProfile {
  userId         String   @id
  subjects       String[]
  weakTopics     String[]
  studyStyle     String
  preferredTimes Json
  goals          String[]
  user           User     @relation(fields: [userId], references: [id])
}

model TutorProfile {
  userId           String    @id
  subjects         String[]
  levelsTaught     String[]
  verificationPath VerifPath
  gradesProof      String?
  hourlyRate       Int
  bio              String
  isVerified       Boolean   @default(false)
  verifiedAt       DateTime?
  rating           Float     @default(0)
  totalSessions    Int       @default(0)
  mpesaNumber      String?
  availability     Json
  user             User      @relation(fields: [userId], references: [id])
}

model MatchRequest {
  id         String     @id @default(cuid())
  studentId  String
  subject    String
  topic      String?
  tier1Tried Boolean    @default(false)
  tier2Tried Boolean    @default(false)
  resolvedAs MatchTier?
  sessionId  String?
  createdAt  DateTime   @default(now())
  resolvedAt DateTime?
}

model Session {
  id            String        @id @default(cuid())
  studentId     String
  partnerId     String?
  tier          MatchTier
  subject       String
  topic         String?
  status        SessionStatus
  roomId        String        @unique
  startedAt     DateTime?
  endedAt       DateTime?
  durationMin   Int?
  pointsAwarded Int           @default(0)
  priceKsh      Int           @default(0)
  paymentStatus PayStatus     @default(NONE)
  mpesaRef      String?
  messages      Message[]
  review        Review?
  partner       User?         @relation("TutorSessions", fields: [partnerId], references: [id])
  student       User          @relation("StudentSessions", fields: [studentId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  senderId  String?
  content   String
  isMash    Boolean  @default(false)
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())
  sender    User?    @relation(fields: [senderId], references: [id])
  session   Session  @relation(fields: [sessionId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id])
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  session    Session  @relation(fields: [sessionId], references: [id])
}

model DailyChallenge {
  id          String                  @id @default(cuid())
  subject     String
  level       EduLevel
  formYear    Int?
  question    String
  options     String[]
  answer      String
  explanation String
  date        DateTime
  attempts    DailyChallengeAttempt[]
}

model DailyChallengeAttempt {
  id           String         @id @default(cuid())
  userId       String
  challengeId  String
  correct      Boolean
  pointsEarned Int
  createdAt    DateTime       @default(now())
  challenge    DailyChallenge @relation(fields: [challengeId], references: [id])
  user         User           @relation(fields: [userId], references: [id])

  @@unique([userId, challengeId])
}

model StruggleGroup {
  id        String   @id @default(cuid())
  subject   String
  topic     String
  level     EduLevel
  members   String[]
  tutorId   String?
  status    String
  createdAt DateTime @default(now())
}

model TutorApplication {
  id         String    @id @default(cuid())
  userId     String    @unique
  path       VerifPath
  gradesUrl  String?
  subjects   String[]
  status     AppStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  actionUrl String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model FeedPost {
  id        String     @id @default(cuid())
  userId    String
  content   String
  image     String?
  subject   String?
  level     EduLevel?
  likes     Int        @default(0)
  createdAt DateTime   @default(now())
  comments  Comment[]
  user      User       @relation(fields: [userId], references: [id])
  likedBy   PostLike[]
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  icon        String
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

enum EduLevel {
  HIGH_SCHOOL
  UNIVERSITY
}

enum Tier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  LEGEND
}

enum VerifPath {
  POINTS
  GRADES
}

enum MatchTier {
  TUTOR
  PEER
  MASH
}

enum SessionStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PayStatus {
  NONE
  HELD
  RELEASED
  REFUNDED
}

enum AppStatus {
  PENDING
  APPROVED
  REJECTED
}
