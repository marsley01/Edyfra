In the study room page:

'use client';

import { useState } from 'react';
import { VideoProvider, useVideoContext } 
  from '@/components/video/VideoProvider';
import { StartCallButton } 
  from '@/components/video/StartCallButton';
import { IncomingCall } 
  from '@/components/video/IncomingCall';
import { ActiveCall } 
  from '@/components/video/ActiveCall';
import type { Call } 
  from '@stream-io/video-react-sdk';

function StudyRoomContent({
  roomId,
  currentUser,
  otherUser,
  subject,
}: StudyRoomProps) {
  const [activeCall, setActiveCall] = 
    useState<Call | null>(null);

  const handleCallAccepted = (call: Call) => {
    setActiveCall(call);
  };

  const handleCallEnded = () => {
    setActiveCall(null);
  };

  if (activeCall) {
    return (
      <ActiveCall
        call={activeCall}
        onEnd={handleCallEnded}
        subject={subject}
      />
    );
  }

  return (
    <div className="study-room-layout">
      
      <IncomingCall 
        onAccepted={handleCallAccepted} 
      />
      
      <div className="study-room-chat">
        {/* Existing Stream Chat here */}
      </div>
      
      <div className="study-room-toolbar">
        <StartCallButton
          roomId={roomId}
          otherUserId={otherUser.id}
          otherUserName={otherUser.name}
        />
      </div>
      
    </div>
  );
}

export default function StudyRoom(
  props: StudyRoomProps
) {
  return (
    <VideoProvider>
      <StudyRoomContent {...props} />
    </VideoProvider>
  );
}

