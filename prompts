import { StreamVideoClient } 
  from '@stream-io/video-react-sdk';

let client: StreamVideoClient | null = null;
let clientUserId: string | null = null;

export async function getStreamVideoClient(
): Promise<StreamVideoClient | null> {
  
  // If client exists for same user, reuse it
  const res = await fetch(
    '/api/stream/video-token',
    { credentials: 'include' }
  );
  
  if (!res.ok) {
    console.error('Failed to get video token:', 
      res.status);
    return null;
  }
  
  const { token, userId, userName, apiKey } = 
    await res.json();
  
  // If already initialized for this user, return
  if (client && clientUserId === userId) {
    return client;
  }
  
  // Disconnect previous client if different user
  if (client && clientUserId !== userId) {
    await client.disconnectUser();
    client = null;
  }
  
  // Create new client
  client = new StreamVideoClient({
    apiKey,
    user: { id: userId, name: userName },
    token,
  });
  
  clientUserId = userId;
  console.log('Stream Video client created 
    for user:', userId);
  
  return client;
}

export async function disconnectVideoClient() {
  if (client) {
    try {
      await client.disconnectUser();
      console.log('Stream Video client 
        disconnected');
    } catch (err) {
      console.error('Disconnect error:', err);
    } finally {
      client = null;
      clientUserId = null;
    }
  }
}

